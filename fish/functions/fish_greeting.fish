    # Select a random character
    set character_count (count $character_quote_arrays)
    if test $character_count -gt 0
        if test $character_count -eq 1
            set random_index 1
        else
            set random_index (random 1 $character_count)
        end
        set selected_character $character_quote_arrays[$random_index]

        # Get the quotes for the selected character
        set selected_quotes $$selected_character

        # Select a random quote from the character's quotes
        set quote_count (count $selected_quotes)
        if test $quote_count -gt 0
            if test $quote_count -eq 1
                set quote_index 1
            else
                set quote_index (random 1 $quote_count)
            end
            set selected_quote $selected_quotes[$quote_index]
        else
            set selected_quote "No quotes available for this character."
        end
    else
        set selected_quote "No characters available."
    end

    # Apply colors and print the quote
    if test $character_count -gt 0
        set_color $fg_colors[$random_index] --background=$bg_colors[$random_index]
    else
        set_color white --background=black
    end
    printf '%s\n' (string split '\n' -- $selected_quote)
    set_color normal
